# =============================================================================
# MathCoin — Environment Variables
# =============================================================================
# Copy to .env and fill in real values.
# .env is gitignored and NEVER committed.
#
# Sections:
#   1. DATABASE (required)
#   2. AUTH — JWT verification (required)
#   3. FRONTEND (required for local dev)
#   4. ON-CHAIN — Base Sepolia (OPTIONAL — core game works without these)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. DATABASE (required for the API)
# -----------------------------------------------------------------------------
# Supabase local: copy from `supabase status` output (DB URL field).
# Or any Postgres connection string.
DATABASE_URL=postgres://user:password@localhost:5432/mathcoin_dev
TEST_DATABASE_URL=postgres://user:password@localhost:5432/mathcoin_test

# -----------------------------------------------------------------------------
# 2. AUTH — JWT verification (required)
# -----------------------------------------------------------------------------
# Mode: "jwks" (asymmetric, recommended) or "shared_secret" (HS256)
JWT_VERIFICATION_MODE=jwks

# JWKS mode (default): point at your Supabase project's JWKS endpoint.
# Supabase local: http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
# Supabase cloud: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json

# Shared-secret mode (only if JWT_VERIFICATION_MODE=shared_secret):
# JWT_SECRET=your-supabase-jwt-secret

# JWT claims validation (both modes):
# Supabase local: http://127.0.0.1:54321/auth/v1
# Supabase cloud: https://<project-ref>.supabase.co/auth/v1
JWT_ISS=http://127.0.0.1:54321/auth/v1
JWT_AUD=authenticated

# -----------------------------------------------------------------------------
# 3. FRONTEND (required for CORS + web dev)
# -----------------------------------------------------------------------------
# Vite dev server default:
FRONTEND_ORIGIN=http://localhost:5173

# Optional: bind address override (default: 127.0.0.1:3000).
# In Docker / cloud hosts, set PORT to bind 0.0.0.0:$PORT.
# PORT=3000
# BIND_ADDRESS=0.0.0.0:3000

# Logging (optional):
RUST_LOG=mathcoin_api=debug,tower_http=debug

# -----------------------------------------------------------------------------
# 4. ON-CHAIN — Base Sepolia testnet (ALL OPTIONAL)
# -----------------------------------------------------------------------------
# If CONTRACT_ADDRESS is NOT set, the on-chain layer is disabled and
# the core game (auth + gameplay + in-app wallet) runs standalone.
# On-chain features (claim/audit/relay) will return 503 "on-chain disabled".
#
# To enable: deploy MathCoin.sol to Base Sepolia with Foundry, then:
#   CONTRACT_ADDRESS=0x...           # deployed contract address
#   CHAIN_NAME=base_sepolia          # or "base" for mainnet (not deployed)
#   CHAIN_ID=84532                   # 8453 for mainnet
#   EXPLORER_URL=https://sepolia.basescan.org
#   BASE_RPC_URL=https://sepolia.base.org
#   RELAYER_PRIVATE_KEY=0x...        # testnet-only relayer key (no real funds)
CONTRACT_ADDRESS=
CHAIN_NAME=base_sepolia
CHAIN_ID=84532
EXPLORER_URL=https://sepolia.basescan.org
BASE_RPC_URL=https://sepolia.base.org
RELAYER_PRIVATE_KEY=
