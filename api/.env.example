# Mirror of root .env.example — for running the API standalone (`cd api && cargo run`).
# The root .env.example is the single source of truth.
# Copy: cp ../.env.example .env  or fill in only the vars below.
DATABASE_URL=postgres://user:password@localhost:5432/mathcoin_dev
TEST_DATABASE_URL=postgres://user:password@localhost:5432/mathcoin_test
RUST_LOG=mathcoin_api=debug,tower_http=debug
PORT=3000
