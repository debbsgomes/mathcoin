# Copy to .env and fill in real values
DATABASE_URL=postgres://user:password@localhost:5432/mathcoin_dev
TEST_DATABASE_URL=postgres://user:password@localhost:5432/mathcoin_test
JWT_VERIFICATION_MODE=jwks
JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
JWT_AUD=authenticated
JWT_ISS=https://your-project.supabase.co/auth/v1
RUST_LOG=mathcoin_api=debug,tower_http=debug
FRONTEND_ORIGIN=http://localhost:5173

# -- On-chain (Base Sepolia testnet only) --
# Set these after deploying MathCoin.sol to Base Sepolia
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CHAIN_NAME=base_sepolia
CHAIN_ID=84532
EXPLORER_URL=https://sepolia.basescan.org
BASE_RPC_URL=https://sepolia.base.org
RELAYER_PRIVATE_KEY=0x...
